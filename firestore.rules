 rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    // Using simple auth check for testing, preferably request.auth.token.email_verified == true
    function isAuthenticated() { return isSignedIn(); }

    function isOptionalString(data, key, maxSize) {
      return !data.keys().hasAny([key]) || (data[key] is string && data[key].size() <= maxSize);
    }
    function isOptionalNumber(data, key) {
      return !data.keys().hasAny([key]) || (data[key] is number);
    }

    // ------------------------------------------------------------
    // 1. Users
    // ------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'points', 'createdAt', 'updatedAt']) &&
             true &&
             data.email is string && data.email.size() <= 256 &&
             data.points is number && data.points >= 0 &&
             (data.createdAt is number || data.createdAt is timestamp) && (data.updatedAt is number || data.updatedAt is timestamp) &&
             isOptionalString(data, 'displayName', 100) &&
             isOptionalString(data, 'pairedCoupleId', 128) &&
             isOptionalNumber(data, 'streak');
    }

    match /users/{userId} {
      function isOwner() { return isAuthenticated() && request.auth.uid == userId; }
      
      allow get: if isOwner();
      allow list: if false; // Strict PII isolation
      
      allow create: if isOwner() && isValidId(userId) && isValidUser(incoming()) &&
                    // incoming().email == request.auth.token.email && // Relaxed for emulator if needed, but keeping strict usually.
                    (incoming().createdAt is timestamp || incoming().createdAt is number);
                    
      // Allow updates that only modify allowed fields. Skip full user validation to permit partial updates.
      allow update: if isAuthenticated() &&
            incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'pairedCoupleId', 'points', 'streak', 'lastActiveDate', 'updatedAt']);
    }

    // ------------------------------------------------------------
    // 1.6 Achievements
    // ------------------------------------------------------------
    match /achievements/{userId}/items/{itemId} {
      function isOwner() { return isAuthenticated() && request.auth.uid == userId; }

      allow get: if isOwner();
      allow list: if isOwner();

      allow create: if isOwner() && isValidId(itemId);
      allow update: if isOwner() && isValidId(itemId);
      allow delete: if isOwner() && isValidId(itemId);
    }

    // ------------------------------------------------------------
    // 1.5 Pairing Codes
    // ------------------------------------------------------------
    function isValidPairingCode(data) {
       return data.keys().hasAll(['userId', 'createdAt']) &&
              true &&
              data.userId is string && data.userId.size() <= 128 &&
              data.createdAt is number;
    }
    match /pairingCodes/{code} {
       allow get: if isAuthenticated();
       allow create: if isAuthenticated() && isValidPairingCode(incoming()) && incoming().userId == request.auth.uid;
       allow update: if isAuthenticated() && isValidPairingCode(incoming()) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
       allow delete: if isAuthenticated() && existing().userId == request.auth.uid;
    }

    // ------------------------------------------------------------
    // 2. Couples
    // ------------------------------------------------------------
    function isValidCouple(data) {
      return data.keys().hasAll(['user1Id', 'user2Id', 'status', 'totalScore', 'createdAt', 'updatedAt']) &&
             true &&
             data.user1Id is string && data.user1Id.size() <= 128 &&
             data.user2Id is string && data.user2Id.size() <= 128 &&
             data.status in ['pending', 'active'] &&
             data.totalScore is number && data.totalScore >= 0 &&
             (data.createdAt is number || data.createdAt is timestamp) && (data.updatedAt is number || data.updatedAt is timestamp) &&
             isOptionalString(data, 'coupleName', 100);
    }

    match /couples/{coupleId} {
      function isMember() {
        return isAuthenticated() && (resource == null || existing().user1Id == request.auth.uid || existing().user2Id == request.auth.uid);
      }
      function isIncomingMember() {
        return isAuthenticated() && (incoming().user1Id == request.auth.uid || incoming().user2Id == request.auth.uid);
      }

      allow get: if isAuthenticated(); // Allowed to get to check if it exists, members are protected if it does
      allow list: if isAuthenticated() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
      
      allow create: if isIncomingMember() && isValidId(coupleId) && isValidCouple(incoming()) &&
                    (incoming().createdAt is timestamp || incoming().createdAt is number);
                    
      allow update: if isAuthenticated() && (existing().user1Id == request.auth.uid || existing().user2Id == request.auth.uid) && isValidCouple(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'coupleName', 'totalScore', 'updatedAt']) &&
                    incoming().user1Id == existing().user1Id &&
                    incoming().user2Id == existing().user2Id &&
                    incoming().createdAt == existing().createdAt &&
                    (incoming().updatedAt is timestamp || incoming().updatedAt is number);
                    
      // 2.1 Couple Messages
      // Updated to match client implementation which uses a Firestore timestamp field named 'timestamp'
      function isValidMessage(data) {
         return data.keys().hasAll(['senderId', 'text', 'timestamp']) &&
                true &&
                data.senderId is string && data.senderId.size() <= 128 &&
                data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
                data.timestamp is timestamp;
      }
      match /messages/{messageId} {
         allow get: if isAuthenticated();
         allow list: if isAuthenticated();
         
          // Allow creation of a message if the user is authenticated, the message ID is valid,
          // the payload matches the expected schema, and the sender matches the authenticated user.
          // The timestamp check is simplified to ensure the field exists and is a valid timestamp.
          allow create: if isAuthenticated() && isValidId(messageId) && isValidMessage(incoming()) &&
                        incoming().senderId == request.auth.uid &&
                        incoming().timestamp is timestamp;
         
         allow update: if false; // Messages are immutable
         allow delete: if false;
      }
      
    // 2.2 Couple Sessions
    function isValidSession(data) {
       return data.keys().hasAll(['coupleId', 'type', 'status', 'state', 'createdAt', 'updatedAt']) &&
              true &&
              data.coupleId is string && data.coupleId.size() <= 128 &&
              data.type in ['quiz', 'minigame'] &&
              data.status in ['waiting', 'playing', 'finished'] &&
              data.state is map && // arbitrary state for flexibility
              (data.createdAt is number || data.createdAt is timestamp) && (data.updatedAt is number || data.updatedAt is timestamp) &&
              isOptionalString(data, 'quizTitle', 100);
    }
      match /sessions/{sessionId} {
         allow get: if isAuthenticated();
         allow list: if isAuthenticated();
         
         allow create: if isAuthenticated() && isValidId(sessionId) && isValidSession(incoming()) &&
                       incoming().coupleId == coupleId &&
                       (incoming().createdAt is timestamp || incoming().createdAt is number);
                       
         allow update: if isAuthenticated() && isValidSession(incoming()) &&
                       existing().status != 'finished' && // Terminal state mapping
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'state', 'updatedAt']) &&
                       incoming().coupleId == existing().coupleId &&
                       incoming().type == existing().type &&
                       incoming().createdAt == existing().createdAt &&
                       true;

         allow delete: if isAuthenticated() &&
                       (get(/databases/$(database)/documents/couples/$(coupleId)).data.user1Id == request.auth.uid ||
                        get(/databases/$(database)/documents/couples/$(coupleId)).data.user2Id == request.auth.uid);
      }
    }
    
    // ------------------------------------------------------------
    // 3. Quizzes (Global / Community)
    // ------------------------------------------------------------
    function isValidQuiz(data) {
       return data.keys().hasAll(['creatorId', 'title', 'description', 'questions', 'isPublic', 'createdAt']) &&
              true &&
              data.creatorId is string && data.creatorId.size() <= 128 &&
              data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
              data.description is string && data.description.size() <= 500 &&
              data.questions is list && data.questions.size() <= 50 &&
              data.isPublic is bool &&
              (data.createdAt is number || data.createdAt is timestamp);
    }
    
    match /quizzes/{quizId} {
       allow get: if isAuthenticated();
       allow list: if isAuthenticated();
       
       allow create: if isAuthenticated() && isValidId(quizId) && isValidQuiz(incoming()) &&
                     incoming().creatorId == request.auth.uid &&
                     (incoming().createdAt is timestamp || incoming().createdAt is number);
                     
       allow update: if isAuthenticated() && isValidQuiz(incoming()) &&
                     existing().creatorId == request.auth.uid && // Only creator
                     incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'questions', 'isPublic']) &&
                     incoming().creatorId == existing().creatorId &&
                     incoming().createdAt == existing().createdAt;

       allow delete: if isAuthenticated() && existing().creatorId == request.auth.uid;
    }
  }
}
