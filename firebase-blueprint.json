{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and stats",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "pairedCoupleId": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "points", "createdAt", "updatedAt"]
    },
    "Couple": {
      "title": "Couple",
      "description": "Pairing of two users",
      "type": "object",
      "properties": {
        "user1Id": { "type": "string" },
        "user2Id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "coupleName": { "type": "string" },
        "totalScore": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["user1Id", "user2Id", "status", "totalScore", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message in a couple",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string", "maxLength": 1000 },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz definition",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "questions": { "type": "array" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["creatorId", "title", "questions", "isPublic", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "Active game session",
      "type": "object",
      "properties": {
        "coupleId": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "minigame"] },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "state": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["coupleId", "type", "status", "state", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/couples/{coupleId}": {
      "schema": { "$ref": "#/entities/Couple" },
      "description": "Couples collection"
    },
    "/couples/{coupleId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Private messages for a couple"
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Quiz definitions"
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Active game sessions"
    }
  }
}
